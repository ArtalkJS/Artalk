{
  "name": "eslint-plugin-artalk",
  "version": "1.0.3",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/ArtalkJS/Artalk/tree/master/ui/eslint-plugin-artalk",
  "files": [
    "dist"
  ],
  "main": "dist/main.cjs",
  "types": "dist/main.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      },
      "default": {
        "types": "./dist/main.d.mts",
        "default": "./dist/main.mjs"
      }
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "test": "vitest"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.59.1"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.60.1",
    "eslint": "^10.4.1",
    "tsdown": "^0.22.1"
  },
  "peerDependencies": {
    "eslint": ">=9"
  }
}
