{
  "name": "@artalk/plugin-kit",
  "version": "1.0.9",
  "description": "The plugin kit for Artalk",
  "type": "module",
  "main": "dist/main.cjs",
  "types": "dist/main.d.cts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      },
      "default": {
        "types": "./dist/main.d.mts",
        "default": "./dist/main.mjs"
      }
    },
    "./client": "./client.d.ts"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@microsoft/api-extractor": "^7.58.7",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "artalk": "workspace:^",
    "tsdown": "^0.21.10",
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "artalk": "workspace:^",
    "typescript": "*",
    "vite": "*"
  }
}
