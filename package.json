{
  "name": "artalk-monorepo",
  "private": true,
  "homepage": "https://artalk.js.org",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.19.0",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "dev": "pnpm -F artalk dev",
    "dev:sidebar": "pnpm -F @artalk/artalk-sidebar dev",
    "dev:docs": "pnpm -F=docs dev:docs",
    "dev:landing": "pnpm -F=docs-landing dev",
    "build": "pnpm -F artalk build",
    "build:sidebar": "pnpm -F @artalk/artalk-sidebar build",
    "build:all": "pnpm build && pnpm build:sidebar",
    "build:plugins": "pnpm -F @artalk/plugin-* build",
    "build:auth": "pnpm -F @artalk/plugin-auth build",
    "build:plugin-kit": "pnpm -F @artalk/plugin-kit build",
    "build:eslint-plugin": "pnpm -F eslint-plugin-artalk build",
    "build:typedoc": "pnpm typedoc",
    "build:docs": "pnpm build && pnpm build:plugins && pnpm -F=docs-landing build && pnpm -F=docs-swagger swagger:build && pnpm -F=docs build:docs && pnpm after:build-docs",
    "after:build-docs": "cp -rf docs/landing/dist/* docs/swagger/dist/* docs/docs/.vitepress/dist && pnpm build:typedoc && pnpm fetch:registry",
    "fetch:registry": "node scripts/fetch-registry.mjs -- --docs-build",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint": "pnpm lint:eslint && pnpm lint:prettier",
    "lint:fix": "pnpm lint:eslint --fix && pnpm lint:prettier --write",
    "check:publish": "node scripts/check-npm-publish.mjs",
    "prepare": "pnpm build:plugin-kit && pnpm build:eslint-plugin",
    "test": "pnpm -F artalk test"
  },
  "devDependencies": {
    "@artalk/plugin-kit": "workspace:*",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "7.58.7",
    "@playwright/test": "^1.59.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-artalk": "workspace:*",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "terser": "5.46.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "8.0.10",
    "vite-plugin-checker": "0.13.0",
    "vite-plugin-dts": "5.0.0",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0"
  },
  "browserslist": [
    ">0.5%, maintained node versions, not dead, not op_mini all, last 2 years"
  ],
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-import>eslint": "10",
        "eslint-plugin-react>eslint": "10"
      }
    }
  }
}
